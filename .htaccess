# XAMPP Local Development .htaccess
# Modified for localhost compatibility

# Enable mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Set base URL for localhost
    RewriteBase /EXAMs/
    
    # Skip rewriting for actual files and directories
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
</IfModule>

# Prevent directory listing
Options -Indexes
